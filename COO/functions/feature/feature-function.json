        "success_view",
        "major_parts",
        "part_clarification",
        "experience_ui",
        "boundaries",
        "open_decisions",
        "whole_onion_freeze"
      ]
    }
  },
  "lifecycle": {
    "lifecycle_id": "feature-lifecycle-v1-draft",
    "entrypoint": "requirements-gathering",
    "default_phase_order": [
      "requirements-gathering",
      "design",
      "planning",
      "setup-analysis",
      "implementation",
      "finalization",
      "postmortem"
    ],
    "phase_routing_rules": [
      "Requirements always start from CEO-facing high-level intake.",
      "Design is required only when the feature crosses the design complexity gate.",
      "Simple features may route directly from requirements to planning.",
      "Setup-analysis is required for substantial work or any work that benefits from explicit execution mapping.",
      "Implementation may start only after approved planning and setup-analysis, unless setup-analysis is explicitly waived.",
      "Postmortem completes the feature from the CEO point of view."
    ],
    "phases": [
      {
        "phase_id": "requirements-gathering",
        "owner": "COO",
        "purpose": "Turn a vague CEO request into a frozen requirement package without losing business intent.",
        "entry_from": [
          "CEO vague or high-level feature request"
        ],
        "step_sequence": [
          "high-level-definition",
          "feature-frame-and-scope",
          "readiness-check",
          "feature-scope-freeze",
          "requirement-package-and-cto-handoff"
        ],
        "exception_paths": [
          "pushback-ceo-alert"
        ],
        "gates": [
          "UI Freeze Gate",
          "Requirement Freeze Gate",
          "Requirement Readiness Gate"
        ],
        "review_required": true,
        "ui_policy": "If UI is involved, mockup alignment happens here before freeze.",
        "outputs": [
          "frozen requirement package",
          "confirmed task identity",
          "requirements closeout evidence",
          "readiness-reviewed handoff bundle"
        ],
        "handoff_to": [
          "design",
          "planning"
        ],
        "ceo_checkpoint": "explicit_scope_freeze"
      },
      {
        "phase_id": "design",
        "owner": "CTO / Design Function",
        "purpose": "Turn a frozen requirement package into an approved design contract when complexity requires design-first routing.",
        "entry_from": [
          "requirements-gathering"
        ],
        "entry_condition": "design_complexity_gate_passed",
        "step_sequence": [
          "confirm-routed-entry",
          "draft-or-revise-design-contract",
          "design-self-check",
          "governed-design-review",
          "redesign-if-rejected",
          "freeze-approved-design",
          "write-controller-receipts"
        ],
        "gates": [
          "Design Entry Gate",
          "Design Contract Gate",
          "Design Self-Check Gate",
          "Design Approval Gate"
        ],
        "review_required": true,
        "outputs": [
          "approved design contract",
          "design review evidence",
          "design guide updates",
          "design handoff bundle"
        ],
        "handoff_to": [
          "planning"
        ],
        "ceo_checkpoint": "only_if_approved_intent_scope_or_behavior_changes"
      },
      {
        "phase_id": "planning",
        "owner": "CTO / Planning Function",
        "purpose": "Turn requirements or approved design into execution authority that implementers can follow without guessing.",
        "entry_from": [
          "requirements-gathering",
          "design"
        ],
        "step_sequence": [
          "classify-planning-source",
          "planning-entry-gate",
          "load-learning-and-context",
          "discover-gaps",
          "draft-or-revise-plan-spec",
          "planning-self-check",
          "no-guessing-readiness-check",
          "governed-planning-review",
          "redesign-if-rejected",
          "freeze-approved-plan-spec"
        ],
        "gates": [
          "Artifact Classification Gate",
          "No-Guessing Gate",
          "Planning Approval Gate"
        ],
        "review_required": true,
        "outputs": [
          "approved plan/spec",
          "planning draft",
          "planning review evidence",
          "setup-analysis-ready handoff"
        ],
        "handoff_to": [
          "setup-analysis"
        ],
        "ceo_checkpoint": "only_if_business_decision_needed"
      },
      {
        "phase_id": "setup-analysis",
        "owner": "CTO / Execution Analysis Function",
        "purpose": "Turn approved planning authority into a concrete execution map, dependency set, and safe parallel branch plan.",
        "entry_from": [
          "planning"
        ],
        "step_sequence": [
          "confirm-approved-planning-source",
          "identify-execution-units-and-dependencies",
          "mark-safe-parallel-branches",
          "identify-aot-and-missing-capability",
          "generate-execution-map",
          "setup-analysis-self-check",
          "governed-setup-analysis-review",
          "refine-if-rejected",
          "handoff-approved-execution-map"
        ],
        "gates": [
          "Source Approval Gate",
          "Execution Map Gate",
          "Setup-Analysis Approval Gate"
        ],
        "review_required": true,
        "outputs": [
          "execution-map.json",
          "execution-map.md",
          "dependency gate list",
          "parallel branch plan",
          "implementation readiness bundle"
        ],
        "handoff_to": [
          "implementation"
        ],
        "ceo_checkpoint": "only_if_business_decision_needed"
      },
      {
        "phase_id": "implementation",
        "owner": "Implementation Department",
        "purpose": "Execute the approved plan/spec and execution map in bounded phases without redesigning upstream authority.",
        "entry_from": [
          "setup-analysis"
        ],
        "step_sequence": [
          "confirm-implementation-authority",
          "execute-governed-phase",
          "phase-self-check-or-equivalent-closeout",
          "advance-only-after-explicit-phase-closeout",
          "governed-implementation-review",
          "revise-if-rejected",
          "close-approved-implementation-state",
          "prepare-postmortem-inputs"
        ],
        "gates": [
          "Implementation Entry Gate",
          "Phase Closeout Gate",
          "Implementation Approval Gate",
          "Implementation Closeout Gate"
        ],
        "review_required": true,
        "lane_policy": {
          "default_lane_shape": "single_main_lane",
          "parallel_lanes_allowed": true,
          "parallel_lanes_condition": "Only when setup-analysis declares safe parallel branches and governing execution authority permits it.",
          "parallel_branch_ownership_required": true,
          "sub_lane_term": "** TBD **"
        },
        "outputs": [
          "implemented changes",
          "phase closeout artifacts",
          "implementation review evidence",
          "implementation closeout evidence",
          "postmortem-ready bundle"
        ],
        "handoff_to": [
          "finalization"
        ],
        "ceo_checkpoint": "only_if_business_decision_needed"
      },
      {
        "phase_id": "finalization",
        "owner": "COO / Finalization Function",
        "purpose": "Act as safeguard closeout before final CEO-visible completion, enforce clean tree, validate durable evidence, and prepare the postmortem boundary.",
        "entry_from": [
          "implementation"
        ],
        "step_sequence": [
          "load-finalization-state",
          "refresh-learning",
          "validate-closeout-artifacts",
          "validate-merge-readiness-when-required",
          "verify-brain-and-discussion-close-obligations",
          "shut-down-owned-processes",
          "refresh-dependency-map-when-available",
          "clean-disposable-scratch-and-write-finalization-artifacts"
        ],
        "gates": [
          "Brain Closeout Gate",
          "Closeout Validation Gate",
          "Cleanup Gate"
        ],
        "review_required": "** TBD **",
        "outputs": [
          "finalization status",
          "finalization report",
          "validated durable closeout evidence",
          "postmortem input bundle"
        ],
        "handoff_to": [
          "postmortem"
        ],
        "ceo_checkpoint": "no"
      },
      {
        "phase_id": "postmortem",
        "owner": "COO / Board Learning Function",
        "purpose": "Preserve what happened, measure outcome, classify findings and improvements, and produce the real CEO-visible closeout.",
        "entry_from": [
          "finalization"
        ],
        "step_sequence": [
          "determine-postmortem-type-and-depth",
          "preserve-raw-evidence",
          "summarize-step-cycle-or-run",
          "verify-closeout-and-lifecycle-fidelity",
          "extract-findings-lessons-and-evidence",
          "classify-findings",
          "decide-next-action-and-route-or-apply",
          "record-result-and-refresh-learning",
          "close-postmortem-scope"
        ],
        "gates": [
          "Postmortem Type Gate",
          "Governance Fidelity Gate",
          "Classification Gate",
          "Closeout Gate"
        ],
        "review_required": "** TBD **",
        "outputs": [
          "postmortem summary",
          "raw evidence",
          "lessons intake",
          "runtime evolution summary",
          "requirement-to-runtime evidence summary",
          "cycle health summary",
          "brain evidence record",
          "CEO closeout package"
        ],
        "ceo_closeout_payload": [
          "result",
          "run summary",
          "improvements"
        ],
        "handoff_to": [
          "merger-engine"
        ],
        "ceo_checkpoint": "feature_done_after_this_phase"
      }
    ]
  },
  "post_lifecycle_handoff": {
    "target": "merger-engine",

  "terminology": {
    "hierarchy": [
      "company_function",
      "lifecycle",
      "phase",
      "step",
      "lane"
    ],
    "cross_cutting_terms": [
      "gate",
      "handoff"
    ],
    "notes": [
      "Review is not a taxonomy level.",
      "Review may appear as a step, a gate, or an invoked shared mechanism.",
      "CEO-facing language should stay at the company-function and lifecycle level by default."
    ]
  },
  "authority_format": {
    "function_definition": "JSON",
    "lane_authority": "JSON",
    "role_authority": "structured_tagged_markdown",
    "rulebook": "JSON",
    "contract": "JSON"
  },
  "mission": {
    "ceo_value": [
      "take vague high-level feature demand",
      "shape it into governed implementation authority",
      "deliver production-quality results",
      "preserve durable state so the CEO does not need to remember operational details"
    ],
    "phase_1_goal": "Perfect governed execution of features from vague request to postmortem.",
    "not_now": [
      "finance-heavy company functions",
      "marketing-heavy company functions",
      "broad staffing systems",
      "speculative platform abstractions outside the implementation startup mission"
    ]
  },
  "ceo_coo_interface": {
    "ceo_entry_mode": "high_level_by_default",
    "requirements_model": "onion",
    "executive_brief_sections": [
      "Issues That Need Your Attention",
      "On The Table",
      "In Motion",
      "What's Next"
    ],
    "brief_defaults": {
      "style": "focused",
      "max_forward_items": 2
    },
    "brief_learning": {
      "enabled": true,
      "source": "memory_engine",
      "analysis_trigger": "every_5_briefs",
      "status": "draft"
    }
  },
  "approval_policy": {
    "requirements_freeze": "CEO explicit approval required",
    "ui_freeze": "CEO explicit approval required when UI is involved",
    "local_resolution_rule": "If conflicts can be resolved locally at runtime, COO/CTO must resolve them locally.",
    "escalation_required_when": [
      "approved intent changes",
      "approved scope changes",
      "user-visible or business-visible product behavior changes",
      "priority changes affect other approved work",
      "an approved requirement would be deferred, waived, or weakened",
      "the resolution would have irreversible or destructive impact",
      "material cost or effort changes"
    ],
    "final_closeout": "CEO sees the feature as done only after postmortem."
  },
  "alert_policy": {
    "no_silent_stall": true,
    "blocked_or_rejected_feature": "urgent_ceo_alert",
    "in_session_behavior": "surface_immediately",
    "background_behavior": "surface_first_on_next_interaction",
    "ceo_response_options": [
      "address_now",
      "defer"
    ],
    "alert_persistence": "until_explicitly_resolved_or_deferred"
  },
  "state_integration": {
    "collection_model": "bottom_up",
    "presentation_model": "top_down",
    "canonical_shape": "folding_context_tree_json",
    "root_buckets": [
      "Issues",
      "On The Table",
      "In Motion",
      "Completed"
    ],
    "coo_access_model": "pointer_to_tree_snapshot",
    "node_api": [
      "summary()"
    ],
    "notifications": {
      "watch_registration_supported": true,
      "examples": [
        "notify when feature X is implemented",
        "notify when a blocked feature changes state"
      ]
    }
  },
  "audit_and_traceability": {
    "all_internal_decisions_logged": true,
    "all_problems_logged": true,
    "all_fixes_logged": true,
    "kpis_logged_per_step": true,
    "file_crud_requires_commit_at_step_closeout": true,
    "mandatory_clean_handoff_between_phases": true,
    "handover_layers": {
      "substep_layer": [
        "decision logging",
        "finding and problem logging",
        "fix logging",
        "KPI logging",
        "evidence capture"
      ],
      "handover_layer": [
        "clean tree check",
        "required-file commit check",
        "run summary",
        "next-step package assembly"
      ]
    },
    "sink_contract": {
      "raw_evidence": "** TBD **",
      "brain_memory": "** TBD **",
      "telemetry_metrics": "** TBD **"
    }
  },
  "delivery_policy": {
    "development_workspace_root": "dev/",
    "development_workspace_shape": "dev/<feature-key>/",
    "workspace_isolation_recommendation": "git_worktree",
    "finalization_role": "safeguard",
    "dirty_tree_behavior": {
      "governance_pushback": true,
      "pushback_payload": [
        "acceptance failure reason",
        "list of uncommitted files"
      ],
      "self_heal_on_rogue_component": true
    },
    "temp_file_policy": {
      "delete_temp_files_by_finalization": true,
      "keep_nonvolatile_audit_and_postmortem_files": true
    },
    "merge_policy": {
      "merge_after": "postmortem",
      "merge_engine": "merger-engine",
      "merge_engine_status": "** TBD **",
      "branch_deleted_after_merge": true
    }
  },
  "dependency_impact_governance": {
    "enabled": true,
    "reference_doc": "C:/ADF/docs/v0/dependency-map.md",

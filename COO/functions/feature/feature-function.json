{
  "Name": "feature",
  "SchemaVersion": "0.4-draft",
  "RequirementsFile": "finalized-requirement-list",

  "Governance": {
    "RoleFormat": "markdown-with-tags",
    "RulesFormat": "json",
    "ContractFormat": "json",
    "Approval": {
      "RequirementScopeFreeze": "ceo-explicit",
      "UiFreeze": "ceo-explicit-if-ui",
      "DoneAfter": "lifecycle-postmortem"
    },
    "EscalateOn": [
      "intent-change",
      "scope-change",
      "user-visible-behavior-change",
      "business-visible-behavior-change",
      "priority-change-affecting-other-approved-work",
      "approved-requirement-waiver",
      "approved-requirement-deferment",
      "irreversible-impact",
      "destructive-impact",
      "material-cost-change",
      "material-effort-change"
    ],
    "AlertPolicy": {
      "NoSilentStall": true,
      "BlockedOrRejected": "urgent-ceo-alert",
      "InSession": "immediate",
      "Background": "next-interaction-first",
      "CeoOptions": [
        "address-now",
        "defer"
      ]
    },
    "StateTree": {
      "Collection": "bottom-up",
      "Presentation": "top-down",
      "Shape": "folding-context-tree",
      "Root": [
        "Issues",
        "OnTheTable",
        "InMotion",
        "Completed"
      ],
      "NodeApi": [
        "summary"
      ],
      "Notifications": true
    },
    "Delivery": {
      "WorkspaceRoot": "dev/",
      "WorkspacePattern": "dev/<feature-key>/",
      "Isolation": "git-worktree",
      "MergeAfter": "lifecycle-postmortem",
      "Merger": "merger-engine",
      "DeleteBranchAfterMerge": true
    },
    "Effort": {
      "Format": "json",
      "Precedence": [
        "project-default",
        "feature-override",
        "run-override"
      ]
    },
    "DependencyImpact": {
      "Enabled": true,
      "Reference": "docs/v0/dependency-map.md"
    }
  },

  "Builder": {
    "Uses": "function-builder",
    "Contract": "COO/functions/feature/contracts/function-builder-contract.json",
    "Settings": "COO/functions/feature/settings/function-builder-settings.json",
    "Overrides": null,
    "Subtools": [
      "phase-builder",
      "step-builder",
      "lane-builder",
      "gate-builder",
      "handoff-builder",
      "agent-role-builder",
      "llm-tool-builder"
    ]
  },

  "SharedObjects": {
    "Engines": {
      "Phase": {
        "Id": "phase-engine",
        "DependsOn": [
          "review-cycle-engine",
          "finalization-engine",
          "postmortem-engine",
          "handoff-engine"
        ]
      },
      "ComplianceStep": {
        "Id": "compliance-step-engine",
        "DependsOn": []
      },
      "ArtifactStep": {
        "Id": "artifact-step-engine",
        "DependsOn": []
      },
      "ReviewCycle": {
        "Id": "review-cycle-engine",
        "DependsOn": [
          "review-engine",
          "learning-engine",
          "component-repair-engine"
        ]
      },
      "Finalization": {
        "Id": "finalization-engine",
        "DependsOn": [
          "component-repair-engine"
        ]
      },
      "Postmortem": {
        "Id": "postmortem-engine",
        "DependsOn": []
      },
      "Handoff": {
        "Id": "handoff-engine",
        "DependsOn": []
      },
      "Lane": {
        "Id": "lane-engine",
        "DependsOn": [
          "phase-engine"
        ]
      }
    }
  },


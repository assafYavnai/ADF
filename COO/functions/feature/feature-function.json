  "lifecycle": {
    "lifecycle_id": "feature-lifecycle-v1-draft",
    "entrypoint": "finalized-requirement-list-handoff",
    "entry_contract": {
      "producer": "COO requirements-gathering lane",
      "artifact": "finalized requirement list",
      "producer_state": "finalized",
      "future_queue_owner": "CTO",
      "future_queue_note": "In the fuller company model, the COO passes the finalized requirement list to the CTO, who decides when the feature reaches its real starting point.",
      "current_scope_queue_behavior": "skip_cto_queue_and_call_feature_entry_directly",
      "first_feature_target_state": "frozen",
      "failure_route": "pushback_to_coo",
      "note": "The feature function starts only after COO handoff. It does not start from vague CEO input. The first feature-function phase tries to turn the finalized requirement list into a frozen requirement list."
    },
    "default_phase_order": [
      "requirement-list-approval",
      "design",
      "planning",
      "setup-analysis",
      "implementation",
      "finalization",
      "postmortem"
    ],
    "phase_routing_rules": [
      "The COO owns requirements gathering before the feature function starts.",
      "In the fuller company model, the COO passes the finalized requirement list to the CTO, who decides when the feature reaches its starting point.",
      "For the current scope, the CTO queue/admission layer is intentionally skipped and the feature function begins directly from a finalized requirement-list handoff.",
      "The first feature-function phase tries to reach a frozen requirement-list state or pushes back to the COO.",
      "Design is required only when the feature crosses the design complexity gate.",
      "Simple features may route directly from requirement-list-approval to planning.",
      "Setup-analysis is required for substantial work or any work that benefits from explicit execution mapping.",
      "Implementation may start only after approved planning and setup-analysis, unless setup-analysis is explicitly waived.",
      "Postmortem completes the feature from the CEO point of view."
    ],
    "phases": [
      {
        "phase_id": "requirement-list-approval",
        "owner": "Feature Function / Requirements Approval",
        "purpose": "Take the COO-finalized requirement list, try to reach a frozen requirement-list state, or push back to the COO if it is not freeze-ready.",
        "phase_template_ref": "phase_engine",
        "phase_members": {
          "entry_from": [
            "COO finalized requirement list handoff"
          ],
          "state_transition": {
            "entry_state": "finalized",
            "success_state": "frozen",
            "failure_state": "pushback_to_coo"
          },
          "create_artifact": {
            "enabled": false,
            "reason": "The governing artifact is received from the COO handoff."
          },
          "phase_artifact": "frozen requirement list",
          "phase_gates": [
            "Finalized Requirement List Entry Gate",
            "Frozen Requirement List Gate"
          ],
          "handoff_routes": [
            "design",
            "planning"
          ],
          "pushback_target": "COO",
          "ceo_checkpoint": "pushback_returns_through_coo"
        },
        "engine_bindings": {
          "phase_engine": {
            "contract": "requirement-list-approval-phase-contract",
            "settings": {
              "skip_create_artifact": true,
              "clean_handoff_required": true
            }
          },
          "review_cycle_engine": {
            "role": "requirements-approval-review-board",
            "rules": "requirements-rulebook",
            "contract": "requirement-list-approval-review-contract",
            "settings": {
              "max_cycles": "** TBD **",
              "strict_mode": true,
              "allow_local_fix_loop": true
            }
          },
          "finalization_engine": {
            "role": "requirements-finalizer",
            "rules": "requirements-rulebook",
            "contract": "requirement-list-approval-finalization-contract",
            "settings": {
              "commit_required": true,
              "cleanup_required": true
            }
          },
          "postmortem_engine": {
            "role": "requirements-postmortem-analyst",
            "rules": "requirements-rulebook",
            "contract": "requirement-list-approval-postmortem-contract",
            "settings": {
              "depth": "phase",
              "route_lessons": true
            }
          },
          "handoff_engine": {
            "role": "requirements-handoff-controller",
            "rules": "requirements-rulebook",
            "contract": "requirement-list-approval-handoff-contract",
            "settings": {
              "default_route": "complexity_gate",
              "pushback_route": "COO"
            }
          }
        },
        "phase_specific_outputs": [
          "frozen requirement list",
          "requirements approval evidence",
          "pushback package to COO when freeze fails",
          "design-or-planning handoff bundle"
        ]
      },
      {
        "phase_id": "design",
        "owner": "CTO / Design Function",
        "purpose": "Turn a frozen requirement package into an approved design contract when complexity requires design-first routing.",
        "phase_template_ref": "phase_engine",
        "phase_members": {
          "entry_from": [
            "requirement-list-approval"
          ],
          "entry_condition": "design_complexity_gate_passed",
          "create_artifact": {
            "enabled": true,
            "artifact": "design contract",
            "artifact_owner": "designer"
          },
          "phase_artifact": "approved design contract",
          "phase_gates": [
            "Design Entry Gate",
            "Design Approval Gate"
          ],
          "handoff_routes": [
            "planning"
          ],
          "pushback_target": "upstream authority",
          "ceo_checkpoint": "only_if_approved_intent_scope_or_behavior_changes"
        },
        "engine_bindings": {

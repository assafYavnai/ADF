  "schema_refs": {
    "shared_review_contract": "shared/learning-engine/review-contract.json",
    "code_review_contract": "shared/learning-engine/code-review-contract.json",
    "compliance_map": "shared/learning-engine/compliance-map.ts#ComplianceMap",
    "fix_items_map": "shared/learning-engine/fix-items-map.ts#FixItemsMap",

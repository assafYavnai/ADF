+test("reopened scope retires finalized requirement memory and resets CTO admission state", async (t) => {
+  resetTelemetryForTests();
+  configureSink(async () => {});
+  t.after(async () => {
+    await closeTelemetry({ timeoutMs: 100 });
+    resetTelemetryForTests();
+  });
+
+  const projectRoot = await mkdtemp(join(tmpdir(), "adf-onion-live-cto-admission-reopen-"));
+  await mkdir(join(projectRoot, "docs", "phase1"), { recursive: true });
+  const threadsDir = join(projectRoot, "threads");
+  const store = new FileSystemThreadStore(threadsDir);
+  const thread = createThread("assafyavnai/adf/coo-freeze-to-cto-admission-wiring");
+  const readyState = buildReadyToFreezeState();
+  const workingArtifact = buildWorkingScopeArtifact(readyState);
+
+  thread.workflowState = {
+    active_workflow: "requirements_gathering_onion",
+    onion: OnionWorkflowThreadState.parse({
+      trace_id: "onion::cto-admission-reopen-test",
+      last_turn_id: "turn-009",
+      lifecycle_status: "awaiting_freeze_approval",
+      current_layer: "whole_onion_freeze",
+      selected_next_question: "Approve freezing the whole scope?",
+      no_question_reason: null,
+      state: readyState,
+      working_artifact: workingArtifact,
+      requirement_artifact: null,
+      finalized_requirement_memory_id: null,
+      cto_admission: null,
+      latest_audit_trace: {
+        trace_id: "onion::cto-admission-reopen-test",
+        turn_id: "turn-009",
+        current_layer: "whole_onion_freeze",
+        workflow_step: "freeze_requested",
+        decision_reason: "The scope is ready for explicit freeze approval.",
+        selected_next_question: "Approve freezing the whole scope?",
+        no_question_reason: null,
+        freeze_blockers: [],
+        open_decisions_snapshot: [],
+        artifact_change_summary: ["Prepared the whole-onion freeze request."],
+        result_status: "freeze_requested",
+      },
+      latest_llm_calls: [],
+      latest_persistence_receipts: [],
+    }),
+  };
+  thread.events.push(
+    createEvent(
+      "user_input",
+      { message: "Approve the freeze and build the CTO admission packet." },
+      createSystemProvenance("COO/requirements-gathering/live/onion-live.test"),
+    ),
+  );
+
+  const finalizedRequirementMemoryId = "44444444-4444-4444-8444-444444444444";
+  await handleRequirementsGatheringOnion({
+    userMessage: "Approve the freeze and build the CTO admission packet.",
+    thread,
+    store,
+    config: {
+      projectRoot,
+      telemetryPartition: "proof",
+      intelligenceParams: {
+        cli: "codex",
+        model: "gpt-5.4",
+        reasoning: "medium",
+        timeout_ms: 5_000,
+      },
+      invokeLLM: async (params) => buildInvocationResult(
+        params,
+        JSON.stringify({
+          freeze_response: {
+            action: "approve",
+            note: "Approved for CTO admission handoff.",
+          },
+        }),
+      ),
+      brainCreateFinalizedRequirementCandidate: async () => ({
+        id: finalizedRequirementMemoryId,
+      }),
+      brainManageMemory: async () => ({
+        success: true,
+        status: "locked",
+        affected_rows: 1,
+      }),
+      brainPublishFinalizedRequirement: async () => ({
+        success: true,
+        status: "locked",
+        affected_rows: 1,
+      }),
+    },
+  });
+
+  const firstOnion = thread.workflowState.onion;
+  assert.ok(firstOnion);
+  assert.equal(firstOnion.finalized_requirement_memory_id, finalizedRequirementMemoryId);
+  assert.equal(firstOnion.cto_admission?.status, "admission_pending_decision");
+
+  thread.workflowState = {
+    active_workflow: "requirements_gathering_onion",
+    onion: OnionWorkflowThreadState.parse({
+      ...firstOnion,
+      lifecycle_status: "active",
+      selected_next_question: "What changed in the scope?",
+      state: {
+        ...firstOnion.state,
+        freeze_status: {
+          status: "draft",
+          blockers: ["Scope reopened for revision."],
+        },
+        approved_snapshot: null,
+      },
+    }),
+  };
+  thread.events.push(
+    createEvent(
+      "user_input",
+      { message: "Reopen the scope to revise part boundaries." },
+      createSystemProvenance("COO/requirements-gathering/live/onion-live.test"),
+    ),
+  );
+
+  let supersedeCalls = 0;
+  const reopenResult = await handleRequirementsGatheringOnion({
+    userMessage: "Reopen the scope to revise part boundaries.",
+    thread,
+    store,
+    config: {
+      projectRoot,
+      telemetryPartition: "proof",
+      intelligenceParams: {
+        cli: "codex",
+        model: "gpt-5.4",
+        reasoning: "medium",
+        timeout_ms: 5_000,
+      },
+      invokeLLM: async (params) => buildInvocationResult(params, "{}"),
+      brainManageMemory: async (action) => {
+        if (action === "supersede") {
+          supersedeCalls += 1;
+        }
+        return {
+          success: true,
+          status: "superseded",
+          affected_rows: 1,
+        };
+      },
+    },
+  });
+
+  const reopenedOnion = thread.workflowState.onion;
+  assert.ok(reopenedOnion);
+  assert.equal(reopenedOnion.finalized_requirement_memory_id, null);
+  assert.equal(reopenedOnion.cto_admission?.status, "admission_not_started");
+  assert.equal(reopenedOnion.cto_admission?.artifact_paths.request_json, null);
+  assert.equal(supersedeCalls, 1);
+  assert.ok(
+    reopenedOnion.latest_persistence_receipts.some(
+      (receipt) => receipt.kind === "superseded_requirement_retire" && receipt.success,
+    ),
+  );
+  assert.match(reopenResult.state_commit_summary, /ready for explicit whole-onion freeze approval/i);
+});
+

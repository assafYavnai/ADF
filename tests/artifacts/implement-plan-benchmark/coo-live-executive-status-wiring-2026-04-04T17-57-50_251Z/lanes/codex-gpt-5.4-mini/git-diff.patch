+function summarizeLiveSourceFacts(facts: BriefSourceFacts): {
+  missingSourceCount: number;
+  liveSourceFreshnessAgeMs: number;
+} {
+  const sourceFamilies = facts.sourceFamilies ?? [];
+  if (sourceFamilies.length === 0) {
+    return {
+      missingSourceCount: 0,
+      liveSourceFreshnessAgeMs: Date.now() - new Date(facts.collectedAt).getTime(),
+    };
+  }
+
+  const missingSourceCount = sourceFamilies.filter((family) => !family.available).length;

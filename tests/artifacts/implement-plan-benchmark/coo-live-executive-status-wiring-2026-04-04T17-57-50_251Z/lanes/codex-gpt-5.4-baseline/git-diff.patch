diff --git a/docs/phase1/coo-live-executive-status-wiring/context.md b/docs/phase1/coo-live-executive-status-wiring/context.md
index ac826e1..fbba059 100644
--- a/docs/phase1/coo-live-executive-status-wiring/context.md

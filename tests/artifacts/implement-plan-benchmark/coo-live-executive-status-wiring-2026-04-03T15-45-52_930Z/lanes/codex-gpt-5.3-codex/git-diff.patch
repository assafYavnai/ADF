@@ -177,3 +177,101 @@ export function buildAndRenderWithKpi(facts: BriefSourceFacts): InstrumentedBrie
 
   return { brief, rendered, metrics };
 }
+
+// ---------------------------------------------------------------------------
+// Live executive status KPI instrumentation
+// ---------------------------------------------------------------------------
+
+export interface LiveStatusKpiRecord {
+  success: boolean;
+  buildLatencyMs: number;
+  sourceAgeMs: number;
+  sourcePartition: "production" | "proof" | "mixed";
+  missingSourceCount: number;
+  parity: BriefParityCounts;
+}
+
+export interface LiveStatusKpiReport {
+  live_exec_brief_build_latency_ms: { p50: number; p95: number; p99: number };
+  slow_status_build_buckets: { over1s: number; over10s: number; over60s: number };
+  live_exec_brief_render_success_count: number;
+  live_exec_brief_render_failure_count: number;
+  live_status_invocation_count: number;
+  live_source_adapter_missing_source_count: number;
+  issues_visibility_parity_count: number;
+  table_visibility_parity_count: number;
+  in_motion_visibility_parity_count: number;
+  next_visibility_parity_count: number;
+  live_source_freshness_age_ms: number | null;
+  observed_source_partitions: Array<"production" | "proof" | "mixed">;
+}
+
+const liveStatusRecords: LiveStatusKpiRecord[] = [];
+
+export function recordLiveStatusMetrics(record: LiveStatusKpiRecord): void {
+  liveStatusRecords.push(record);
+}
+
+export function resetLiveStatusMetrics(): void {
+  liveStatusRecords.length = 0;
+}
+
+export function getLiveStatusKpiReport(): LiveStatusKpiReport {
+  if (liveStatusRecords.length === 0) {
+    return {
+      live_exec_brief_build_latency_ms: { p50: 0, p95: 0, p99: 0 },
+      slow_status_build_buckets: { over1s: 0, over10s: 0, over60s: 0 },
+      live_exec_brief_render_success_count: 0,
+      live_exec_brief_render_failure_count: 0,
+      live_status_invocation_count: 0,
+      live_source_adapter_missing_source_count: 0,
+      issues_visibility_parity_count: 0,
+      table_visibility_parity_count: 0,
+      in_motion_visibility_parity_count: 0,
+      next_visibility_parity_count: 0,
+      live_source_freshness_age_ms: null,
+      observed_source_partitions: [],
+    };
+  }
+
+  const latencies = liveStatusRecords.map((record) => record.buildLatencyMs).sort((a, b) => a - b);
+  const parityMatches = liveStatusRecords.reduce((acc, record) => {
+    if (record.parity.issuesExpected === record.parity.issuesActual) acc.issues++;
+    if (record.parity.tableExpected === record.parity.tableActual) acc.table++;
+    if (record.parity.inMotionExpected === record.parity.inMotionActual) acc.inMotion++;
+    if (record.parity.whatsNextExpected === record.parity.whatsNextActual) acc.next++;
+    return acc;
+  }, { issues: 0, table: 0, inMotion: 0, next: 0 });
+
+  const partitionOrder: Array<"production" | "proof" | "mixed"> = ["production", "proof", "mixed"];
+  const partitionSet = new Set<"production" | "proof" | "mixed">(liveStatusRecords.map((record) => record.sourcePartition));
+  const observedSourcePartitions = partitionOrder.filter((partition) => partitionSet.has(partition));
+
+  const latest = liveStatusRecords[liveStatusRecords.length - 1];
+
+  return {
+    live_exec_brief_build_latency_ms: {
+      p50: percentile(latencies, 0.50),
+      p95: percentile(latencies, 0.95),
+      p99: percentile(latencies, 0.99),
+    },
+    slow_status_build_buckets: {
+      over1s: latencies.filter((latency) => latency > SLOW_THRESHOLDS_MS[0]).length,
+      over10s: latencies.filter((latency) => latency > SLOW_THRESHOLDS_MS[1]).length,
+      over60s: latencies.filter((latency) => latency > SLOW_THRESHOLDS_MS[2]).length,
+    },
+    live_exec_brief_render_success_count: liveStatusRecords.filter((record) => record.success).length,
+    live_exec_brief_render_failure_count: liveStatusRecords.filter((record) => !record.success).length,
+    live_status_invocation_count: liveStatusRecords.length,
+    live_source_adapter_missing_source_count: liveStatusRecords.reduce(
+      (total, record) => total + record.missingSourceCount,
+      0,
+    ),
+    issues_visibility_parity_count: parityMatches.issues,
+    table_visibility_parity_count: parityMatches.table,
+    in_motion_visibility_parity_count: parityMatches.inMotion,
+    next_visibility_parity_count: parityMatches.next,
+    live_source_freshness_age_ms: latest.sourceAgeMs,
+    observed_source_partitions: observedSourcePartitions,
+  };
+}

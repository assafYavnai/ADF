{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "tools/implementation-engine/schemas/governance-routing-record.schema.json",
    "title":  "Implementation Engine Governance Routing Record",
    "type":  "object",
    "required":  [
                     "schema_version",
                     "job_id",
                     "round_id",
                     "recorded_at_utc",
                     "record_status",
                     "proposals"
                 ],
    "properties":  {
                       "schema_version":  {
                                              "type":  "string",
                                              "const":  "1.0"
                                          },
                       "job_id":  {
                                      "type":  "string",
                                      "minLength":  1
                                  },
                       "round_id":  {
                                        "type":  "string",
                                        "minLength":  1
                                    },
                       "record_status":  {
                                             "type":  "string",
                                             "enum":  [
                                                          "pending",
                                                          "mixed",
                                                          "complete"
                                                      ]
                                         },
                       "generated_from":  {
                                              "type":  "array",
                                              "items":  {
                                                            "type":  "string",
                                                            "enum":  [
                                                                         "review",
                                                                         "learning",
                                                                         "compliance",
                                                                         "parity_audit"
                                                                     ]
                                                        },
                                              "uniqueItems":  true
                                          },
                       "proposals":  {
                                         "type":  "array",
                                         "minItems":  1,
                                         "items":  {
                                                       "$ref":  "#/$defs/proposal"
                                                   }
                                     },
                       "recorded_at_utc":  {
                                               "type":  "string",
                                               "format":  "date-time"
                                           }
                   },
    "additionalProperties":  false,
    "$defs":  {
                  "proposal":  {
                                   "type":  "object",
                                   "required":  [
                                                    "proposal_id",
                                                    "target_surface",
                                                    "requested_action",
                                                    "owner",
                                                    "base_version",
                                                    "gatekeeper_outcome",
                                                    "paths"
                                                ],
                                   "properties":  {
                                                      "proposal_id":  {
                                                                          "type":  "string",
                                                                          "minLength":  1
                                                                      },
                                                      "target_surface":  {
                                                                             "type":  "string",
                                                                             "enum":  [
                                                                                          "rulebook",
                                                                                          "contract",
                                                                                          "validator_or_enforcer",
                                                                                          "review_prompt",
                                                                                          "docs_only"
                                                                                      ]
                                                                         },
                                                      "requested_action":  {
                                                                               "type":  "string",
                                                                               "enum":  [
                                                                                            "create",
                                                                                            "update",
                                                                                            "replace",
                                                                                            "append",
                                                                                            "defer",
                                                                                            "reject"
                                                                                        ]
                                                                           },
                                                      "owner":  {
                                                                    "type":  "string",
                                                                    "minLength":  1
                                                                },
                                                      "base_version":  {
                                                                           "type":  "string",
                                                                           "minLength":  1
                                                                       },
                                                      "gatekeeper_outcome":  {
                                                                                 "type":  "string",
                                                                                 "enum":  [
                                                                                              "pending",
                                                                                              "approved",
                                                                                              "rejected",
                                                                                              "deferred",
                                                                                              "stale"
                                                                                          ]
                                                                             },
                                                      "paths":  {
                                                                    "type":  "array",
                                                                    "items":  {
                                                                                  "type":  "string",
                                                                                  "minLength":  1
                                                                              },
                                                                    "uniqueItems":  true,
                                                                    "minItems":  1
                                                                },
                                                      "related_finding_ids":  {
                                                                                  "type":  "array",
                                                                                  "items":  {
                                                                                                "type":  "string",
                                                                                                "minLength":  1
                                                                                            },
                                                                                  "uniqueItems":  true
                                                                              },
                                                      "rationale":  {
                                                                        "type":  "string"
                                                                    },
                                                      "gatekeeper_actor":  {
                                                                               "type":  "string",
                                                                               "minLength":  1
                                                                           },
                                                      "decision_recorded_at_utc":  {
                                                                                       "type":  "string",
                                                                                       "format":  "date-time"
                                                                                   },
                                                      "stale_against_version":  {
                                                                                    "type":  "string",
                                                                                    "minLength":  1
                                                                                }
                                                  },
                                   "additionalProperties":  false,
                                   "allOf":  [
                                                 {
                                                     "if":  {
                                                                "properties":  {
                                                                                   "gatekeeper_outcome":  {
                                                                                                              "enum":  [
                                                                                                                           "approved",
                                                                                                                           "rejected",
                                                                                                                           "deferred",
                                                                                                                           "stale"
                                                                                                                       ]
                                                                                                          }
                                                                               }
                                                            },
                                                     "then":  {
                                                                  "required":  [
                                                                                   "gatekeeper_actor",
                                                                                   "decision_recorded_at_utc"
                                                                               ]
                                                              }
                                                 },
                                                 {
                                                     "if":  {
                                                                "properties":  {
                                                                                   "gatekeeper_outcome":  {
                                                                                                              "const":  "stale"
                                                                                                          }
                                                                               }
                                                            },
                                                     "then":  {
                                                                  "required":  [
                                                                                   "stale_against_version"
                                                                               ]
                                                              }
                                                 }
                                             ]
                               }
              }
}

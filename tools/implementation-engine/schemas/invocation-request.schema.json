{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "tools/implementation-engine/schemas/invocation-request.schema.json",
    "title":  "Implementation Engine Invocation Request",
    "type":  "object",
    "required":  [
                     "job_id",
                     "operation",
                     "source_refs",
                     "target_governance"
                 ],
    "properties":  {
                       "job_id":  {
                                      "type":  "string",
                                      "minLength":  1
                                  },
                       "operation":  {
                                         "type":  "string",
                                         "enum":  [
                                                      "create",
                                                      "update",
                                                      "fix"
                                                  ]
                                     },
                       "source_refs":  {
                                           "type":  "array",
                                           "minItems":  1,
                                           "items":  {
                                                         "$ref":  "#/$defs/source_ref"
                                                     },
                                           "description":  "Invocation-scoped authority and baseline evidence for this run. These refs may add case-specific authority or migration evidence, but they must not silently override the canonical target semantics declared by target_governance.authority_documents."
                                       },
                       "target_governance":  {
                                                 "$ref":  "#/$defs/target_governance",
                                                 "description":  "Canonical target-governance package for the artifact being created or revised."
                                             }
                   },
    "additionalProperties":  false,
    "$defs":  {
                  "source_ref":  {
                                     "type":  "object",
                                     "required":  [
                                                      "path",
                                                      "purpose",
                                                      "required"
                                                  ],
                                     "properties":  {
                                                        "path":  {
                                                                     "type":  "string",
                                                                     "minLength":  1
                                                                 },
                                                        "purpose":  {
                                                                        "type":  "string",
                                                                        "minLength":  1
                                                                    },
                                                        "required":  {
                                                                         "type":  "boolean"
                                                                     },
                                                        "content_type":  {
                                                                             "type":  "string",
                                                                             "minLength":  1
                                                                         },
                                                        "notes":  {
                                                                      "type":  "string"
                                                                  }
                                                    },
                                     "additionalProperties":  false
                                 },
                  "governed_surface_ref":  {
                                               "type":  "object",
                                               "required":  [
                                                                "path"
                                                            ],
                                               "properties":  {
                                                                  "path":  {
                                                                               "type":  "string",
                                                                               "minLength":  1
                                                                           },
                                                                  "kind":  {
                                                                               "type":  "string",
                                                                               "enum":  [
                                                                                            "contract",
                                                                                            "rulebook",
                                                                                            "prompt",
                                                                                            "schema",
                                                                                            "artifact"
                                                                                        ]
                                                                           },
                                                                  "must_exist":  {
                                                                                     "type":  "boolean",
                                                                                     "default":  true
                                                                                 }
                                                              },
                                               "additionalProperties":  false
                                           },
                  "target_output_declaration":  {
                                                    "type":  "object",
                                                    "required":  [
                                                                     "path",
                                                                     "artifact_class",
                                                                     "promotion_strategy"
                                                                 ],
                                                    "properties":  {
                                                                       "path":  {
                                                                                    "type":  "string",
                                                                                    "minLength":  1
                                                                                },
                                                                       "artifact_class":  {
                                                                                              "type":  "string",
                                                                                              "minLength":  1
                                                                                          },
                                                                       "promotion_strategy":  {
                                                                                                  "type":  "string",
                                                                                                  "enum":  [
                                                                                                               "frozen_only",
                                                                                                               "frozen_or_conditional",
                                                                                                               "staged_only"
                                                                                                           ]
                                                                                              }
                                                                   },
                                                    "additionalProperties":  false
                                                },
                  "target_governance":  {
                                            "type":  "object",
                                            "required":  [
                                                             "artifact_kind",
                                                             "writable_surface",
                                                             "writable_surface_base_version",
                                                             "target_contract",
                                                             "target_rulebook",
                                                             "target_review_prompt",
                                                             "authority_documents",
                                                             "runtime_review_configuration",
                                                             "output_declarations",
                                                             "stop_conditions",
                                                             "conditional_acceptance_authority"
                                                         ],
                                            "properties":  {
                                                               "artifact_kind":  {
                                                                                     "type":  "string",
                                                                                     "minLength":  1
                                                                                 },
                                                               "writable_surface":  {
                                                                                        "type":  "array",
                                                                                        "minItems":  1,
                                                                                        "uniqueItems":  true,
                                                                                        "items":  {
                                                                                                      "type":  "string",
                                                                                                      "minLength":  1
                                                                                                  }
                                                                                    },
                                                               "target_contract":  {
                                                                                       "$ref":  "#/$defs/governed_surface_ref"
                                                                                   },
                                                               "target_rulebook":  {
                                                                                       "$ref":  "#/$defs/governed_surface_ref"
                                                                                   },
                                                               "target_review_prompt":  {
                                                                                            "$ref":  "#/$defs/governed_surface_ref"
                                                                                        },
                                                               "authority_documents":  {
                                                                                           "type":  "array",
                                                                                           "minItems":  1,
                                                                                           "items":  {
                                                                                                         "$ref":  "#/$defs/source_ref"
                                                                                                     },
                                                                                           "description":  "Canonical authority documents declared by target governance. These define the target artifact semantics the run must satisfy."
                                                                                       },
                                                               "runtime_review_configuration":  {
                                                                                                    "type":  "object",
                                                                                                    "required":  [
                                                                                                                     "review_modes",
                                                                                                                     "max_rounds",
                                                                                                                     "split_verdict_handling",
                                                                                                                     "regression_sanity_required"
                                                                                                                 ],
                                                                                                    "properties":  {
                                                                                                                       "review_modes":  {
                                                                                                                                            "type":  "object",
                                                                                                                                            "required":  [
                                                                                                                                                             "first_round",
                                                                                                                                                             "middle_rounds",
                                                                                                                                                             "regression_sanity"
                                                                                                                                                         ],
                                                                                                                                            "properties":  {
                                                                                                                                                               "first_round":  {
                                                                                                                                                                                   "type":  "string",
                                                                                                                                                                                   "enum":  [
                                                                                                                                                                                                "full"
                                                                                                                                                                                            ]
                                                                                                                                                                               },
                                                                                                                                                               "middle_rounds":  {
                                                                                                                                                                                     "type":  "string",
                                                                                                                                                                                     "enum":  [
                                                                                                                                                                                                  "delta",
                                                                                                                                                                                                  "full"
                                                                                                                                                                                              ]
                                                                                                                                                                                 },
                                                                                                                                                               "regression_sanity":  {
                                                                                                                                                                                         "type":  "string",
                                                                                                                                                                                         "enum":  [
                                                                                                                                                                                                      "regression_sanity"
                                                                                                                                                                                                  ]
                                                                                                                                                                                     }
                                                                                                                                                           },
                                                                                                                                            "additionalProperties":  false
                                                                                                                                        },
                                                                                                                       "max_rounds":  {
                                                                                                                                          "type":  "integer",
                                                                                                                                          "minimum":  1
                                                                                                                                      },
                                                                                                                       "split_verdict_handling":  {
                                                                                                                                                      "type":  "string",
                                                                                                                                                      "enum":  [
                                                                                                                                                                   "rejecting_path_only_then_regression_sanity"
                                                                                                                                                               ]
                                                                                                                                                  },
                                                                                                                       "regression_sanity_required":  {
                                                                                                                                                          "type":  "boolean",
                                                                                                                                                          "const":  true
                                                                                                                                                      }
                                                                                                                   },
                                                                                                    "additionalProperties":  false
                                                                                                },
                                                               "output_declarations":  {
                                                                                           "type":  "object",
                                                                                           "required":  [
                                                                                                            "run_root",
                                                                                                            "candidate_root",
                                                                                                            "staged_final_root",
                                                                                                            "target_outputs"
                                                                                                        ],
                                                                                           "properties":  {
                                                                                                              "run_root":  {
                                                                                                                               "type":  "string",
                                                                                                                               "minLength":  1
                                                                                                                           },
                                                                                                              "candidate_root":  {
                                                                                                                                     "type":  "string",
                                                                                                                                     "minLength":  1
                                                                                                                                 },
                                                                                                              "staged_final_root":  {
                                                                                                                                        "type":  "string",
                                                                                                                                        "minLength":  1
                                                                                                                                    },
                                                                                                              "target_outputs":  {
                                                                                                                                     "type":  "array",
                                                                                                                                     "minItems":  1,
                                                                                                                                     "items":  {
                                                                                                                                                   "$ref":  "#/$defs/target_output_declaration"
                                                                                                                                               }
                                                                                                                                 },
                                                                                                              "preserved_history_outputs":  {
                                                                                                                                                "type":  "array",
                                                                                                                                                "description":  "Optional preserved history outputs. When present, each entry must declare its history behavior and write trigger.",
                                                                                                                                                "items":  {
                                                                                                                                                              "$ref":  "#/$defs/preserved_history_output_declaration"
                                                                                                                                                          }
                                                                                                                                            }
                                                                                                          },
                                                                                           "additionalProperties":  false
                                                                                       },
                                                               "stop_conditions":  {
                                                                                       "type":  "object",
                                                                                       "required":  [
                                                                                                        "budget_exhaustion_outcome",
                                                                                                        "missing_authority_outcome",
                                                                                                        "failed_parity_outcome",
                                                                                                        "blocked_execution_outcome"
                                                                                                    ],
                                                                                       "properties":  {
                                                                                                          "budget_exhaustion_outcome":  {
                                                                                                                                            "type":  "string",
                                                                                                                                            "enum":  [
                                                                                                                                                         "resume_required",
                                                                                                                                                         "blocked"
                                                                                                                                                     ]
                                                                                                                                        },
                                                                                                          "missing_authority_outcome":  {
                                                                                                                                            "type":  "string",
                                                                                                                                            "enum":  [
                                                                                                                                                         "pushback",
                                                                                                                                                         "blocked"
                                                                                                                                                     ]
                                                                                                                                        },
                                                                                                          "failed_parity_outcome":  {
                                                                                                                                        "type":  "string",
                                                                                                                                        "enum":  [
                                                                                                                                                     "pushback",
                                                                                                                                                     "blocked"
                                                                                                                                                 ]
                                                                                                                                    },
                                                                                                          "blocked_execution_outcome":  {
                                                                                                                                            "type":  "string",
                                                                                                                                            "enum":  [
                                                                                                                                                         "blocked"
                                                                                                                                                     ]
                                                                                                                                        }
                                                                                                      },
                                                                                       "additionalProperties":  false
                                                                                   },
                                                               "conditional_acceptance_authority":  {
                                                                                                        "type":  "object",
                                                                                                        "required":  [
                                                                                                                         "owner_type",
                                                                                                                         "owner_ref",
                                                                                                                         "delegated_to_run"
                                                                                                                     ],
                                                                                                        "properties":  {
                                                                                                                           "owner_type":  {
                                                                                                                                              "type":  "string",
                                                                                                                                              "enum":  [
                                                                                                                                                           "invoker",
                                                                                                                                                           "domain_tool",
                                                                                                                                                           "controller"
                                                                                                                                                       ]
                                                                                                                                          },
                                                                                                                           "owner_ref":  {
                                                                                                                                             "type":  "string",
                                                                                                                                             "minLength":  1
                                                                                                                                         },
                                                                                                                           "delegated_to_run":  {
                                                                                                                                                    "type":  "boolean"
                                                                                                                                                }
                                                                                                                       },
                                                                                                        "additionalProperties":  false
                                                                                                    },
                                                               "writable_surface_base_version":  {
                                                                                                     "type":  "string",
                                                                                                     "minLength":  1,
                                                                                                     "description":  "Version or revision token for the bounded writable surface. The engine must fail closed if the live target surface no longer matches this base version before mutation."
                                                                                                 }
                                                           },
                                            "additionalProperties":  false
                                        },
                  "preserved_history_output_declaration":  {
                                                               "type":  "object",
                                                               "required":  [
                                                                                "path",
                                                                                "artifact_class",
                                                                                "history_mode",
                                                                                "write_trigger"
                                                                            ],
                                                               "properties":  {
                                                                                  "path":  {
                                                                                               "type":  "string",
                                                                                               "minLength":  1
                                                                                           },
                                                                                  "artifact_class":  {
                                                                                                         "type":  "string",
                                                                                                         "minLength":  1
                                                                                                     },
                                                                                  "history_mode":  {
                                                                                                       "type":  "string",
                                                                                                       "enum":  [
                                                                                                                    "append_only",
                                                                                                                    "replace_snapshot",
                                                                                                                    "per_terminal_state_snapshot"
                                                                                                                ]
                                                                                                   },
                                                                                  "write_trigger":  {
                                                                                                        "type":  "string",
                                                                                                        "enum":  [
                                                                                                                     "update_or_fix_only",
                                                                                                                     "every_terminal_state",
                                                                                                                     "frozen_only",
                                                                                                                     "frozen_or_conditional"
                                                                                                                 ]
                                                                                                    }
                                                                              },
                                                               "additionalProperties":  false
                                                           }
              }
}
